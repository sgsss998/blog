---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav>
    <h2><a href="/">{SITE_TITLE}</a></h2>
    <div class="internal-links">
      <HeaderLink href="/">首页</HeaderLink>
      <HeaderLink href="/blog">文章</HeaderLink>
      <HeaderLink href="/about">关于</HeaderLink>
    </div>
    <div class="social-links">
      <a href="https://github.com/sgsss998" target="_blank" title="GitHub">
        <span class="sr-only">GitHub</span>
        <svg viewBox="0 0 16 16" aria-hidden="true" width="24" height="24">
          <path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
        </svg>
      </a>
      <button class="wechat-btn" id="wechat-btn" title="微信">
        <span class="sr-only">微信</span>
        <svg viewBox="0 0 24 24" aria-hidden="true" width="24" height="24">
          <path fill="currentColor" d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 0 1 .213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 0 0 .167-.054l1.903-1.114a.864.864 0 0 1 .717-.098 10.16 10.16 0 0 0 2.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178A1.17 1.17 0 0 1 4.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 0 1-1.162 1.178 1.17 1.17 0 0 1-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 0 1 .598.082l1.584.926a.272.272 0 0 0 .14.047c.134 0 .24-.111.24-.247 0-.06-.023-.12-.038-.177l-.327-1.233a.582.582 0 0 1-.023-.156.49.49 0 0 1 .201-.398C23.024 18.48 24 16.82 24 14.98c0-3.21-2.931-5.837-6.656-6.088V8.89c-.135-.004-.268-.025-.407-.032zm-2.53 3.274c.535 0 .969.44.969.982a.976.976 0 0 1-.969.983.976.976 0 0 1-.969-.983c0-.542.434-.982.97-.982zm4.844 0c.535 0 .969.44.969.982a.976.976 0 0 1-.969.983.976.976 0 0 1-.969-.983c0-.542.434-.982.969-.982z"/>
        </svg>
      </button>
    </div>
  </nav>
</header>

<!-- WeChat Modal -->
<div class="wechat-modal" id="wechat-modal">
  <div class="wechat-modal-content">
    <button class="wechat-close" id="wechat-close">&times;</button>
    <h3>添加老明微信</h3>
    <div class="wechat-qrcode">
      <img src="/images/wechat-personal.jpg" alt="老明微信二维码" />
    </div>
  </div>
</div>

<script>
  const btn = document.getElementById('wechat-btn');
  const modal = document.getElementById('wechat-modal');
  const close = document.getElementById('wechat-close');

  btn?.addEventListener('click', () => {
    modal?.classList.add('show');
  });

  close?.addEventListener('click', () => {
    modal?.classList.remove('show');
  });

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
      modal.classList.remove('show');
    }
  });
</script>

<style>
  header {
    margin: 0;
    padding: 0 1em;
    background: white;
    box-shadow: 0 1px 3px rgba(var(--black), 5%);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  h2 {
    margin: 0;
    font-size: 1.1em;
  }
  h2 a, h2 a.active {
    text-decoration: none;
    color: rgb(var(--black));
    font-weight: 700;
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 960px;
    margin: 0 auto;
  }
  nav a {
    padding: 1em 0.8em;
    color: rgb(var(--black));
    text-decoration: none;
    font-size: 0.95em;
    transition: color 0.2s ease;
  }
  nav a:hover {
    color: var(--accent);
  }
  nav a.active {
    border-bottom: 2px solid var(--accent);
    color: var(--accent);
  }
  .social-links, .social-links a {
    display: flex;
    align-items: center;
    gap: 0.5em;
  }
  .social-links a {
    padding: 0.5em;
  }
  .social-links a:hover {
    color: var(--accent);
  }
  .wechat-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5em;
    color: rgb(var(--black));
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
  }
  .wechat-btn:hover {
    color: #07C160;
  }
  /* Modal styles */
  .wechat-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6);
    z-index: 1000;
    justify-content: center;
    align-items: center;
  }
  .wechat-modal.show {
    display: flex;
  }
  .wechat-modal-content {
    background: white;
    padding: 2.5em;
    border-radius: 16px;
    max-width: 90%;
    position: relative;
    text-align: center;
  }
  .wechat-modal-content h3 {
    margin: 0 0 1.5em 0;
    color: rgb(var(--black));
    font-size: 1.3em;
  }
  .wechat-close {
    position: absolute;
    top: 10px;
    right: 15px;
    font-size: 1.5em;
    background: none;
    border: none;
    cursor: pointer;
    color: rgb(var(--gray));
  }
  .wechat-close:hover {
    color: rgb(var(--black));
  }
  .wechat-qrcode img {
    width: 400px;
    max-width: 85vw;
    height: auto;
    border-radius: 8px;
  }
  @media (max-width: 720px) {
    .social-links a:first-child {
      display: none;
    }
    nav a {
      padding: 1em 0.5em;
      font-size: 0.9em;
    }
  }
</style>
