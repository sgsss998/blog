---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, WECHAT_COVER_HEIGHT, WECHAT_COVER_WIDTH } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			.cover {
				aspect-ratio: 900 / 383;
				width: 100%;
				overflow: hidden;
				border-radius: 12px;
				margin-bottom: 0.5rem;
			}
			.cover :global(img) {
				width: 100%;
				height: 100%;
				object-fit: cover;
				object-position: center;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			.view-count {
				margin: 0.25em 0 0 0;
				color: rgb(var(--gray));
				font-size: 0.85em;
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover .cover {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<div class="cover">
											<Image
												width={WECHAT_COVER_WIDTH}
												height={WECHAT_COVER_HEIGHT}
												src={post.data.heroImage}
												alt=""
											/>
										</div>
									)}
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
									<p class="view-count" data-page-url={`/blog/${post.id}/`}>
										👁️ <span class="busuanzi-value">-</span> 次阅读
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
		<script>
			// 获取每篇文章的阅读量
			document.addEventListener('DOMContentLoaded', function() {
				const viewCountElements = document.querySelectorAll('.view-count');

				viewCountElements.forEach(function(el) {
					const pageUrl = el.getAttribute('data-page-url');
					if (!pageUrl) return;

					// 使用 JSONP 获取阅读量
					const callbackName = 'busuanzi_callback_' + Math.random().toString(36).substr(2, 9);

					window[callbackName] = function(data) {
						const valueSpan = el.querySelector('.busuanzi-value');
						if (valueSpan && data && data.page_pv !== undefined) {
							valueSpan.textContent = data.page_pv;
						}
						delete window[callbackName];
					};

					const script = document.createElement('script');
					script.src = 'https://busuanzi.ibruce.info/busuanzi?jsonpCallback=' + callbackName + '&uriPath=' + encodeURIComponent(pageUrl);
					document.body.appendChild(script);
				});
			});
		</script>
	</body>
</html>
